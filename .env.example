# FrontierLab Atlas environment template
# Copy to .env and fill required values.
# Never commit real credentials.

# [Required] Geocoding provider key (maps.co)
MAPS_CO_API_KEY=

# [Optional but recommended] OpenAlex polite-pool contact email
OPENALEX_MAILTO=

# Notes:
# - OPENALEX_API_KEY is NOT used by this project currently.
# - OPENCELLID_API_KEY / HF_TOKEN are legacy variables from other modules,
#   not required for FrontierLab Atlas core flow.
